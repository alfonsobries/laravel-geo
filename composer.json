{
    "name": "alfonsobries/laravel-geo",
    "description": "Geo-location data sync package for Laravel",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "illuminate/support": "^12.0",
        "illuminate/database": "^12.0",
        "illuminate/http": "^12.0",
        "geoip2/geoip2": "^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "AlfonsoBries\\Geo\\": "src/",
            "AlfonsoBries\\Geo\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AlfonsoBries\\Geo\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AlfonsoBries\\Geo\\GeoServiceProvider"
            ],
            "aliases": {
                "Geo": "AlfonsoBries\\Geo\\Facades\\Geo"
            }
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
